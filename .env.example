# biz-reply-composer-demo 環境変数サンプル
# 実値は .env に記載する（.env は .gitignore 済み・平文コミット禁止）。
# デモ制約: 外部API・APIキー・認証なし。ollama へのローカルHTTPのみ。

# 実行環境の判定（development | production）。開発時はセッションを自動初期化する。
APP_ENV=development

# ollama ローカルエンドポイント（ネットワーク越し呼び出しは禁止。127.0.0.1 のみ）
OLLAMA_HOST=http://127.0.0.1:11434

# 既定モデル（§1.3）。中国製モデルは採用しない方針。
OLLAMA_DEFAULT_MODEL=gemma3:1b

# 生成タイムアウト（ミリ秒。§1.5 手順7 = 30秒）
GENERATION_TIMEOUT_MS=30000
